# Server Port
PORT=5000
NODE_ENV=development

# MongoDB — Free Atlas cluster banao: mongodb.com/atlas
# Agar local MongoDB install kiya hai toh: mongodb://localhost:27017/tripgenius
MONGODB_URI=mongodb+srv://aryanxover:afroza@cluster0.heysjcw.mongodb.net/?appName=Cluster0

# JWT Secret — Yeh already fill hai, change kar sakte ho
JWT_SECRET=tripgenius_super_secret_key_2024_change_me_please_make_it_long
JWT_EXPIRE=7d

# Anthropic API Key — OPTIONAL (sirf agar Anthropic AI use karna hai)
# Ollama use kar rahe ho toh yeh blank chhod do
ANTHROPIC_API_KEY=

# Frontend URL (CORS allow karne ke liye)
CLIENT_URL=*
