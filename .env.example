# TripGenius AI - Environment Variables
# Copy this file as .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB - Get free cluster from mongodb.com/atlas
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/tripgenius

# JWT Secret - Koi bhi random string daal do (min 32 chars)
JWT_SECRET=tripgenius_super_secret_jwt_key_change_this_in_production_2024

JWT_EXPIRE=7d

# Anthropic API Key - console.anthropic.com se milegi
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Frontend URL (CORS ke liye)
CLIENT_URL=http://localhost:3000

# File Upload (optional - local storage use hoga by default)
MAX_FILE_SIZE=5242880
